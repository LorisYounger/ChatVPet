<Window x:Class="VPet.Plugin.ChatVPet.winDiary" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VPet.Plugin.ChatVPet" mc:Ignorable="d"
        xmlns:ll="clr-namespace:LinePutScript.Localization.WPF;assembly=LinePutScript.Localization.WPF"
        xmlns:pu="clr-namespace:Panuon.WPF.UI;assembly=Panuon.WPF.UI"
        Title="{ll:Str '桌宠日记'}" Width="560" Height="600" ResizeMode="CanResize" WindowState="Normal">
    <Window.Resources>
        <ResourceDictionary Source="/VPet-Simulator.Windows.Interface;component/ResourceStyle.xaml" />
    </Window.Resources>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header info bar -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock x:Name="tbCount" VerticalAlignment="Center" Margin="0,0,10,0" />
        </StackPanel>

        <!-- Diary list -->
        <ListBox x:Name="lbDiary" Grid.Row="1"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="{DynamicResource SecondaryDarker}" BorderThickness="0,0,0,1" Padding="4,6">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{ll:Str 删除}" Click="MenuItem_Delete"
                                          CommandParameter="{Binding}" />
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!-- Date + meta row -->
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DateLabel}" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryDark}" Margin="0,0,10,0" />
                                <TextBlock Text="{Binding MetaLabel}"
                                           Foreground="{DynamicResource SecondaryText}" FontSize="12"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Summary text -->
                            <TextBlock Grid.Row="1" Text="{Binding Answer}" TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Bottom button bar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
            <Button pu:ButtonHelper.CornerRadius="4" Content="{ll:Str 关闭}" Margin="5,0,0,0"
                    Background="{DynamicResource SecondaryLight}" Padding="10,4" Click="btnClose_Click" />
        </StackPanel>
    </Grid>
</Window>
